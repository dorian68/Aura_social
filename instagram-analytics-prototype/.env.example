PORT=3000
APP_ID=your_meta_app_id
APP_SECRET=your_meta_app_secret
GRAPH_API_VERSION=v23.0
META_AUTH_MODE=instagram

# Required when META_AUTH_MODE=facebook / Facebook Login for Business.
# Permissions are managed inside this Meta configuration; do not pass Instagram scopes directly.
FACEBOOK_LOGIN_CONFIG_ID=

# Instagram Business/Creator account owned by your app/admin.
# Used only for Business Discovery public estimates.
MY_INSTAGRAM_BUSINESS_ID=17841400000000000
MY_LONG_LIVED_ACCESS_TOKEN=EAAB...

FRONTEND_URL=http://localhost:3000
MOCK_META=false

# Optional. Runtime setup is automatically enabled outside production.
# Set this to true only if you intentionally want the setup assistant in production.
ALLOW_RUNTIME_SETUP=false

# Optional local diagnostics. Logs are redacted, but keep them private.
LOG_DIR=../data/instagram/logs
LOG_FILE=../data/instagram/logs/prototype.ndjson
ALLOW_DEBUG_LOGS=false
