<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AURA — Reveal. Connect. Reward.</title>
<link rel="icon" href="assets/aura-logo.png">
<link rel="stylesheet" href="css/aura.css">
<style>
/* ---------- Landing-specific ---------- */
/* ===== IMMERSIVE FULL-BLEED HERO ===== */
.hero-new {
  position:relative; width:100%; overflow:hidden;
  min-height: clamp(580px, 94vh, 940px);
  margin-top: -70px; padding-top: 70px;             /* pull figure up behind the nav */
  display:flex; align-items:center;
}
#heroCanvas { position:absolute; inset:0; width:100%; height:100%; display:block; z-index:0; }
.hero-scrim { position:absolute; inset:0; z-index:1; pointer-events:none;
  background:
    linear-gradient(98deg, var(--ink-800) 4%, rgba(8,11,10,.95) 27%, rgba(8,11,10,.62) 50%, rgba(8,11,10,0) 72%),
    linear-gradient(to bottom, rgba(8,11,10,.5) 0%, transparent 16% 70%, var(--ink-800) 100%);
}
.hero-new-inner { position:relative; z-index:2; width:100%; }
.hero-copy { max-width: 620px; animation: heroIn 1s var(--ease) both; }
@keyframes heroIn { from { opacity:0; transform:translateY(26px); } to { opacity:1; transform:none; } }
.hero-kicker { margin-bottom:20px; }
.hero-copy h1 { margin: 0 0 24px; font-size: clamp(46px, 6.4vw, 88px); letter-spacing:-.035em; }
.hero-copy h1 .hl { color: var(--lime); text-shadow: 0 0 36px rgba(184,255,77,.45); }
.hero-copy .lede { max-width:32em; margin-bottom:34px; }
.hero-actions { display:flex; gap:14px; flex-wrap:wrap; margin-bottom:36px; }
.hero-social { display:flex; align-items:center; gap:15px; }
.avatars { display:flex; }
.avatars .av { width:40px; height:40px; border-radius:50%; border:2px solid var(--ink-800); margin-left:-12px; background:linear-gradient(135deg,#2a3530,#12382b); display:grid; place-items:center; font-size:13px; color:var(--lime); font-family:var(--display); font-weight:600; box-shadow:0 4px 12px rgba(0,0,0,.5); }
.avatars .av:first-child { margin-left:0; }
.hero-social > span { font-size:14px; color:var(--t-mid); line-height:1.45; max-width:18em; }
.fig-pager { position:absolute; z-index:5; bottom:30px; right:34px; display:flex; align-items:center; gap:9px; }
.fig-pager .fp-label { font-family:var(--mono); font-size:10.5px; letter-spacing:.18em; text-transform:uppercase; color:var(--t-lo); margin-right:4px; }
.fig-pager button { width:9px; height:9px; border-radius:50%; background:var(--line-strong); transition:all .25s var(--ease); cursor:pointer; }
.fig-pager button.on { background:var(--lime); box-shadow:0 0 12px var(--lime); width:24px; border-radius:5px; }
.fig-pager button:hover { background:var(--lime-dim); }
.hero-scroll { position:absolute; z-index:5; left:50%; bottom:22px; transform:translateX(-50%); display:flex; flex-direction:column; align-items:center; gap:7px; color:var(--t-lo); font-family:var(--mono); font-size:10.5px; letter-spacing:.2em; text-transform:uppercase; }
.hero-scroll .mouse { width:22px; height:34px; border:1.5px solid var(--line-strong); border-radius:12px; position:relative; }
.hero-scroll .mouse::after { content:""; position:absolute; left:50%; top:6px; width:3px; height:6px; border-radius:2px; background:var(--lime); transform:translateX(-50%); animation:scrollDot 1.8s var(--ease) infinite; }
@keyframes scrollDot { 0%{opacity:0;transform:translate(-50%,0)} 30%{opacity:1} 70%{opacity:1;transform:translate(-50%,9px)} 100%{opacity:0;transform:translate(-50%,12px)} }

/* ===== STAT BAND (metrics row, moved out of the figure) ===== */
.stat-band { position:relative; border-top:1px solid var(--line); border-bottom:1px solid var(--line); background:linear-gradient(180deg, rgba(255,247,232,.018), transparent); }
.stat-row { display:grid; grid-template-columns:repeat(4,1fr); }
.stat-item { padding: clamp(22px,2.4vw,34px) clamp(18px,2vw,30px); position:relative; transition:background .25s; }
.stat-item + .stat-item { border-left:1px solid var(--line); }
.stat-item:hover { background:var(--glass); }
.stat-item .si-top { display:flex; align-items:center; gap:9px; margin-bottom:14px; }
.stat-item .si-ic { width:34px; height:34px; border-radius:10px; background:var(--glass-2); border:1px solid var(--line); display:grid; place-items:center; color:var(--lime); flex:none; }
.stat-item .si-ic svg { width:17px; height:17px; }
.stat-item .si-label { font-size:13px; color:var(--t-mid); font-weight:600; }
.stat-item .si-val { font-family:var(--display); font-weight:600; font-size:clamp(30px,3.4vw,42px); letter-spacing:-.03em; color:var(--cream); line-height:1; }
.stat-item .si-val small { font-size:.4em; color:var(--t-lo); font-weight:500; margin-left:2px; }
.stat-item .si-spark { margin-top:14px; display:block; width:100%; height:30px; overflow:visible; }
.stat-item .si-foot { margin-top:10px; font-size:12px; color:var(--t-lo); display:flex; align-items:center; gap:7px; }

.nav-cta-row { display:flex; align-items:center; gap: 14px; }
.lang-toggle { display:inline-flex; padding:3px; gap:2px; background: var(--ink-700); border:1px solid var(--line); border-radius: var(--r-pill); }
.lang-toggle button { width:34px;height:28px;border-radius:var(--r-pill); font-size:12px; font-weight:700; color: var(--t-lo); font-family:var(--mono); }
.lang-toggle button.active { background: var(--glass-2); color: var(--cream); }

/* hero */
.hero { position:relative; padding-top: clamp(40px,7vw,80px); padding-bottom: clamp(60px,8vw,110px); overflow:hidden; }
.hero-grid { display:grid; grid-template-columns: 1.05fr .95fr; gap: clamp(28px,4vw,70px); align-items:center; }
.hero-eyebrow { margin-bottom: 22px; }
.hero h1 { margin-bottom: 22px; }
.hero .lede { max-width: 30em; margin-bottom: 32px; }
.hero-actions { display:flex; gap:14px; flex-wrap:wrap; align-items:center; }
.hero-note { margin-top: 18px; font-size:13px; color: var(--t-lo); display:flex; align-items:center; gap:8px; }
.hero-note svg { width:15px;height:15px;color:var(--lime); }

/* orbit visual */
.orbit-stage { position:relative; aspect-ratio: 1/1; width:100%; max-width: 520px; margin-inline:auto; display:grid; place-items:center; }
.orbit-ring { position:absolute; border-radius:50%; border:1px solid var(--line); inset:0; }
.orbit-ring.r2 { inset: 13%; border-color: rgba(232,220,200,.07); }
.orbit-ring.r3 { inset: 28%; border-color: rgba(184,255,77,.12); }
.orbit-rotor { position:absolute; inset:0; animation: orbit-spin 36s linear infinite; }
.orbit-rotor.rev { animation: orbit-spin-rev 28s linear infinite; inset:13%; }
.orbit-rotor.r3 { animation: orbit-spin 22s linear infinite; inset:28%; }
.orbit-node { position:absolute; top:-1px; left:50%; transform:translate(-50%,-50%); }
.fan-avatar { width:46px;height:46px;border-radius:50%; border:1.5px solid var(--line-strong); background: var(--ink-500); display:grid;place-items:center; font-family:var(--mono); font-size:12px; color:var(--t-mid); overflow:hidden; box-shadow: var(--shadow-card); }
.fan-avatar.hot { border-color: rgba(184,255,77,.5); color: var(--lime); box-shadow: var(--glow-lime-soft); background: rgba(184,255,77,.06); }
.orbit-core { position:relative; z-index:2; width: 38%; aspect-ratio:1; border-radius:50%;
  display:grid; place-items:center; text-align:center;
  background: radial-gradient(circle at 50% 35%, rgba(184,255,77,.16), rgba(11,15,14,.4) 70%);
  border:1px solid rgba(184,255,77,.25); box-shadow: inset 0 0 40px rgba(184,255,77,.1), var(--glow-lime-soft);
  backdrop-filter: blur(2px);
}
.orbit-core .big { font-family:var(--display); font-size: clamp(34px,5vw,52px); font-weight:600; color:var(--cream); letter-spacing:-.03em; line-height:1; }
.orbit-core .lbl { font-family:var(--mono); font-size:10.5px; letter-spacing:.18em; text-transform:uppercase; color:var(--lime); margin-top:6px; }
.orbit-core .glow-dot { position:absolute; bottom:-2px; left:50%; transform:translateX(-50%); width:60%; height:14px; background:radial-gradient(ellipse, rgba(184,255,77,.5), transparent 70%); filter:blur(3px); }

/* hero product mock */
.mock { background: linear-gradient(180deg, var(--ink-600), var(--ink-700)); border:1px solid var(--line-strong); border-radius: var(--r-xl); padding: 22px; box-shadow: var(--shadow-pop); position:relative; overflow:hidden; max-width: 460px; margin-inline:auto; }
.mock::before { content:""; position:absolute; top:-40%; right:-20%; width:70%; height:70%; background: radial-gradient(circle, rgba(184,255,77,.12), transparent 70%); }
.mock-head { display:flex; align-items:center; gap:13px; position:relative; }
.mock-pfp { width:52px;height:52px;border-radius:50%; background: linear-gradient(135deg,#2a3530,#12382b); border:1.5px solid var(--line-strong); display:grid;place-items:center; font-family:var(--display); color:var(--lime); font-size:20px; }
.mock-kpis { display:grid; grid-template-columns:1fr 1fr; gap:11px; margin-top:18px; position:relative; }
.mock-mini { background: var(--glass); border:1px solid var(--line); border-radius: var(--r-md); padding:13px 14px; }
.mock-mini .v { font-family:var(--display); font-size:24px; font-weight:600; color:var(--cream); letter-spacing:-.02em; }
.mock-mini .l { font-size:11.5px; color:var(--t-lo); margin-top:2px; }
.mock-bar { margin-top:14px; position:relative; }
.mock-bar .top { display:flex; justify-content:space-between; font-size:12px; color:var(--t-mid); margin-bottom:7px; }

/* hero C input */
.hero-c-form { display:flex; flex-direction:column; gap:14px; max-width:440px; }
.hero-c-form .input-ig { padding-right:6px; }
.hero-c-form .input-ig .btn { height:44px; }

/* section header */
.sec-head { max-width: 720px; margin-bottom: clamp(34px,4vw,56px); }
.sec-head .lede { margin-top: 16px; }
.sec-head.center { margin-inline:auto; text-align:center; }
.sec-head.center .eyebrow { justify-content:center; }
.sec-head.center .eyebrow::before { display:none; }

/* problem cards */
.prob-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; }
.prob-ic { width:46px;height:46px;border-radius:13px; background: var(--glass-2); border:1px solid var(--line); display:grid;place-items:center; color:var(--gold-soft); margin-bottom:18px; }
.prob-ic svg{width:22px;height:22px}

/* analyzer preview */
.an-card { display:grid; grid-template-columns: 1.1fr 1fr; gap:0; border:1px solid var(--line-strong); border-radius: var(--r-xl); overflow:hidden; background: var(--ink-700); }
.an-left { padding: clamp(24px,3vw,38px); border-right:1px solid var(--line); position:relative; }
.an-right { padding: clamp(24px,3vw,38px); background: linear-gradient(180deg, var(--glass), transparent); display:flex; flex-direction:column; gap:14px; }
.an-handle { display:flex; align-items:center; gap:14px; margin-bottom:24px; }
.an-metrics { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.score-hero { display:flex; align-items:center; gap:22px; padding:18px; border-radius:var(--r-lg); background: rgba(184,255,77,.05); border:1px solid rgba(184,255,77,.18); }

/* journey */
.journey { position:relative; display:grid; grid-template-columns:repeat(5,1fr); gap:14px; }
.journey::before { content:""; position:absolute; top:31px; left:6%; right:6%; height:1px; background:linear-gradient(90deg,transparent, var(--line-strong) 12%, var(--line-strong) 88%, transparent); }
.j-step { text-align:center; position:relative; }
.j-num { width:62px;height:62px;border-radius:50%; margin:0 auto 18px; display:grid;place-items:center; background:var(--ink-700); border:1px solid var(--line-strong); font-family:var(--display); font-size:22px; color:var(--cream); position:relative; z-index:1; transition: all .3s var(--ease); }
.j-step:hover .j-num { border-color: rgba(184,255,77,.5); color:var(--lime); box-shadow:var(--glow-lime-soft); }
.j-step h4 { font-size:16px; margin-bottom:7px; }
.j-step p { font-size:13.5px; color:var(--t-mid); line-height:1.5; }

/* tokenization */
.tk-grid { display:grid; grid-template-columns: 1.3fr 1fr; gap:28px; align-items:stretch; }
.tk-fans-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; }
.tk-chip { display:flex; align-items:center; gap:11px; padding:14px 16px; border-radius:var(--r-md); background:var(--glass-2); border:1px solid var(--line); font-weight:600; font-size:14.5px; transition:all .2s var(--ease); }
.tk-chip:hover { border-color:rgba(184,255,77,.35); transform:translateX(3px); }
.tk-chip .d { width:9px;height:9px;border-radius:50%; background:var(--lime); box-shadow:0 0 10px var(--lime); flex:none; }
.tk-power { display:flex; flex-direction:column; gap:12px; }
.tk-power-item { padding:16px 18px; border-radius:var(--r-md); border:1px solid var(--line); background:linear-gradient(180deg,var(--glass-2),transparent); }
.tk-power-item b { font-family:var(--display); font-size:17px; color:var(--cream); display:block; margin-bottom:3px; }
.tk-power-item span { font-size:13px; color:var(--t-mid); }

/* dashboard preview */
.db-frame { border:1px solid var(--line-strong); border-radius:var(--r-xl); overflow:hidden; background:var(--ink-900); box-shadow:var(--shadow-pop); }
.db-bar { display:flex; align-items:center; gap:8px; padding:13px 18px; border-bottom:1px solid var(--line); background:var(--ink-800); }
.db-dot { width:11px;height:11px;border-radius:50%; }
.db-body { padding: clamp(20px,2.5vw,30px); }
.db-kpis { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
.db-lower { display:grid; grid-template-columns: 1.4fr 1fr; gap:14px; margin-top:14px; }
.bars { display:flex; align-items:flex-end; gap:10px; height:150px; padding-top:10px; }
.bars .bar { flex:1; border-radius:7px 7px 0 0; background:linear-gradient(180deg,var(--lime),var(--lime-dim)); position:relative; transition:height .8s var(--ease); min-width:0; }
.bars .bar.muted { background:linear-gradient(180deg,var(--forest-300),var(--forest-700)); }
.funnel-row { display:flex; align-items:center; gap:12px; margin-bottom:12px; }
.funnel-bar { height:30px; border-radius:8px; background:linear-gradient(90deg, rgba(184,255,77,.7), rgba(184,255,77,.25)); display:flex; align-items:center; padding-left:12px; font-size:12.5px; font-weight:700; color:#0A1206; }

/* use cases marquee */
.uc-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }
.uc-tile { padding:22px 20px; border-radius:var(--r-lg); border:1px solid var(--line); background:linear-gradient(180deg,var(--glass-2),transparent); display:flex; flex-direction:column; gap:14px; min-height:120px; justify-content:space-between; transition:all .25s var(--ease); cursor:default; }
.uc-tile:hover { border-color:rgba(184,255,77,.3); transform:translateY(-3px); background:linear-gradient(180deg,rgba(184,255,77,.05),transparent); }
.uc-tile .ic { width:40px;height:40px;border-radius:11px; background:var(--glass-2); border:1px solid var(--line); display:grid;place-items:center; color:var(--lime); }
.uc-tile .ic svg{width:20px;height:20px}
.uc-tile h4 { font-size:15px; font-family:var(--body); font-weight:600; color:var(--cream); }

/* proof */
.proof-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; margin-bottom:36px; }
.proof-card { padding:30px 26px; border-radius:var(--r-lg); border:1px solid var(--line); background:linear-gradient(180deg,var(--glass-2),transparent); position:relative; }
.proof-card .v { font-family:var(--display); font-size:clamp(38px,4.5vw,52px); font-weight:600; letter-spacing:-.03em; color:var(--lime); line-height:1; }
.proof-card .l { font-weight:600; color:var(--cream); margin-top:14px; }
.proof-card .d { font-size:13.5px; color:var(--t-mid); margin-top:4px; }
.quote { padding: clamp(30px,4vw,50px); border-radius:var(--r-xl); border:1px solid var(--line-strong); background:linear-gradient(135deg, rgba(18,56,43,.4), var(--ink-700)); position:relative; overflow:hidden; }
.quote blockquote { font-family:var(--display); font-size:clamp(20px,2.4vw,30px); line-height:1.3; color:var(--cream); letter-spacing:-.01em; max-width:20em; }

/* pricing */
.price-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; align-items:stretch; }
.price-card { display:flex; flex-direction:column; padding:28px 24px; border-radius:var(--r-lg); border:1px solid var(--line); background:linear-gradient(180deg,var(--glass-2),transparent); position:relative; transition:all .25s var(--ease); }
.price-card:hover { border-color:var(--line-strong); transform:translateY(-3px); }
.price-card.feat { border-color:rgba(184,255,77,.4); background:linear-gradient(180deg,rgba(184,255,77,.06),transparent); box-shadow:var(--glow-lime-soft); }
.price-card .pname { font-family:var(--display); font-size:18px; color:var(--cream); }
.price-card .pprice { font-family:var(--display); font-size:clamp(32px,3.5vw,42px); font-weight:600; letter-spacing:-.03em; color:var(--cream); margin:14px 0 2px; }
.price-card .pdesc { font-size:13.5px; color:var(--t-mid); min-height:38px; }
.price-feats { list-style:none; display:flex; flex-direction:column; gap:10px; margin:20px 0 24px; flex:1; }
.price-feats li { display:flex; gap:10px; font-size:13.5px; color:var(--t-mid); align-items:flex-start; }
.price-feats svg { width:16px;height:16px;color:var(--lime);flex:none;margin-top:2px; }

/* final cta */
.final-cta { position:relative; text-align:center; padding: clamp(60px,8vw,110px) 0; overflow:hidden; }
.final-cta .glow { position:absolute; inset:0; background:radial-gradient(60% 80% at 50% 120%, rgba(184,255,77,.18), transparent 70%); }

/* footer */
.footer { border-top:1px solid var(--line); padding: 56px 0 40px; }
.foot-grid { display:grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap:30px; margin-bottom:40px; }
.foot-col h5 { font-size:12px; letter-spacing:.14em; text-transform:uppercase; color:var(--t-lo); margin-bottom:16px; font-weight:700; }
.foot-col a { display:block; color:var(--t-mid); font-size:14px; padding:5px 0; transition:color .2s; }
.foot-col a:hover { color:var(--cream); }
.disclaimer { font-size:12px; color:var(--t-lo); line-height:1.6; max-width:60em; padding:18px 0; border-top:1px solid var(--line); }

/* hero switcher (compare directions) */
.hero-switch { position:fixed; right:18px; bottom:18px; z-index:80; display:flex; align-items:center; gap:8px; padding:8px 10px 8px 14px; background:rgba(8,11,10,.85); backdrop-filter:blur(14px); border:1px solid var(--line-strong); border-radius:var(--r-pill); box-shadow:var(--shadow-pop); }
.hero-switch span { font-size:11px; font-family:var(--mono); letter-spacing:.12em; text-transform:uppercase; color:var(--t-lo); }
.hero-switch button { width:30px;height:30px;border-radius:50%; font-family:var(--display); font-weight:600; font-size:14px; color:var(--t-mid); border:1px solid var(--line); transition:all .2s; }
.hero-switch button.active { background:var(--lime); color:#0A1206; border-color:var(--lime); box-shadow:var(--glow-lime-soft); }

.hero-variant { display:none; }
.hero-variant.show { display:block; }

@media (max-width: 900px) {
  .hero-new { min-height: clamp(520px, 86vh, 760px); }
  .hero-copy { max-width: 100%; }
  .hero-scrim { background:
    linear-gradient(180deg, rgba(8,11,10,.35) 0%, rgba(8,11,10,.78) 40%, var(--ink-800) 88%),
    linear-gradient(98deg, rgba(8,11,10,.7) 0%, rgba(8,11,10,.2) 60%, transparent 100%); }
  .stat-row { grid-template-columns:1fr 1fr; }
  .stat-item:nth-child(3), .stat-item:nth-child(4) { border-top:1px solid var(--line); }
  .stat-item:nth-child(3) { border-left:none; }
  .fig-pager { bottom:auto; top:84px; right:18px; }
  .hero-scroll { display:none; }
  .hero-grid, .an-card, .tk-grid, .db-lower { grid-template-columns:1fr; }
  .prob-grid, .uc-grid, .proof-grid, .price-grid, .db-kpis { grid-template-columns:1fr 1fr; }
  .journey { grid-template-columns:1fr 1fr; gap:28px; }
  .journey::before { display:none; }
  .nav-links { display:none; }
  .an-left { border-right:none; border-bottom:1px solid var(--line); }
  .foot-grid { grid-template-columns:1fr 1fr; }
}
@media (max-width: 560px) {
  .prob-grid, .uc-grid, .proof-grid, .price-grid, .db-kpis, .journey { grid-template-columns:1fr; }
  .stat-row { grid-template-columns:1fr; }
  .stat-item + .stat-item { border-left:none; border-top:1px solid var(--line); }
}
</style>
</head>
<body>
<div class="aura-bg"></div>

<!-- ============================ NAV ============================ -->
<nav class="nav">
  <div class="nav-inner">
    <a class="logo-lockup" href="index.html">
      <img src="assets/aura-logo.png" width="42" height="41" alt="AURA">
      
    </a>
    <div class="nav-links">
      <a href="#how" data-t="nav_how"></a>
      <a href="#analyzer" data-t="nav_analyzer"></a>
      <a href="#loyalty" data-t="nav_loyalty"></a>
      <a href="#pricing" data-t="nav_pricing"></a>
    </div>
    <div class="nav-cta-row">
      <div class="lang-toggle">
        <button data-lang-btn="en">EN</button>
        <button data-lang-btn="fr">FR</button>
      </div>
      <a href="product/analyzer.html" class="btn btn-ghost btn-sm" data-t="nav_signin"></a>
      <a href="product/analyzer.html" class="btn btn-primary btn-sm" data-t="nav_cta"></a>
    </div>
  </div>
</nav>

<!-- ============================ HERO ============================ -->
<header class="hero-new">
  <canvas id="heroCanvas"></canvas>
  <div class="hero-scrim"></div>

  <div class="hero-new-inner wrap wrap-wide">
    <div class="hero-copy">
      <div class="eyebrow hero-kicker"><span data-t="hero_badge"></span></div>
      <h1 class="display-xl" data-t-html="heroA_title"></h1>
      <p class="lede" data-t="hero_sub"></p>
      <div class="hero-actions">
        <a href="product/analyzer.html" class="btn btn-primary btn-lg" data-t="hero_primary"></a>
        <a href="#how" class="btn btn-line btn-lg">
          <span data-t="hero_secondary"></span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M10 9l5 3-5 3z" fill="currentColor"/></svg>
        </a>
      </div>
      <div class="hero-social">
        <div class="avatars">
          <span class="av">A</span><span class="av">M</span><span class="av">S</span><span class="av">T</span><span class="av">L</span>
        </div>
        <span data-t-html="hero_proof"></span>
      </div>
    </div>
  </div>

  <div class="fig-pager" id="figPager">
    <span class="fp-label" data-t="hero_figure"></span>
    <button data-fig="wave" title="Wave field"></button>
    <button data-fig="lens" title="Singularity"></button>
    <button data-fig="vortex" title="Vortex"></button>
  </div>

  <a class="hero-scroll" href="#stats" aria-label="Scroll">
    <span class="mouse"></span>
  </a>
</header>

<!-- ============================ STAT BAND ============================ -->
<section class="stat-band" id="stats">
  <div class="wrap wrap-wide stat-row">
    <div class="stat-item" data-reveal data-reveal-delay="1">
      <div class="si-top">
        <span class="si-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round"><circle cx="9" cy="8" r="3"/><path d="M3 20c0-3 2.7-5 6-5s6 2 6 5"/><path d="M16 11a3 3 0 100-6"/></svg></span>
        <span class="si-label" data-t="stat_superfan"></span>
      </div>
      <div class="si-val tnum">86<small>/100</small></div>
      <svg class="si-spark" viewBox="0 0 200 30" preserveAspectRatio="none" data-spark="a"></svg>
      <div class="si-foot"><span class="badge pos">+4</span><span data-t="stat_foot_period"></span></div>
    </div>
    <div class="stat-item" data-reveal data-reveal-delay="2">
      <div class="si-top">
        <span class="si-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="3"/></svg></span>
        <span class="si-label" data-t="stat_token"></span>
      </div>
      <div class="si-val tnum">78<small>/100</small></div>
      <svg class="si-spark" viewBox="0 0 200 30" preserveAspectRatio="none" data-spark="b"></svg>
      <div class="si-foot"><span class="badge pos">+6</span><span data-t="stat_foot_period"></span></div>
    </div>
    <div class="stat-item" data-reveal data-reveal-delay="3">
      <div class="si-top">
        <span class="si-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9"><ellipse cx="12" cy="6" rx="8" ry="3"/><path d="M4 6v6c0 1.7 3.6 3 8 3s8-1.3 8-3V6M4 12v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6"/></svg></span>
        <span class="si-label" data-t="stat_revenue"></span>
      </div>
      <div class="si-val tnum">$8.4K<small>/mo</small></div>
      <svg class="si-spark" viewBox="0 0 200 30" preserveAspectRatio="none" data-spark="c"></svg>
      <div class="si-foot"><span class="badge pos">+18%</span><span data-t="stat_foot_period"></span></div>
    </div>
    <div class="stat-item" data-reveal data-reveal-delay="4">
      <div class="si-top">
        <span class="si-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round"><path d="M3 17l5-5 4 4 8-9"/><path d="M16 7h5v5"/></svg></span>
        <span class="si-label" data-t="stat_conv"></span>
      </div>
      <div class="si-val tnum">3.2<small>%</small></div>
      <svg class="si-spark" viewBox="0 0 200 30" preserveAspectRatio="none" data-spark="d"></svg>
      <div class="si-foot"><span class="badge pos">+0.8</span><span data-t="stat_foot_period"></span></div>
    </div>
  </div>
</section>

<!-- ============================ PROBLEM ============================ -->
<section class="section wrap" id="how">
  <div class="sec-head" data-reveal>
    <div class="eyebrow gold"><span data-t="prob_eyebrow"></span></div>
    <h2 class="display-md" style="margin-top:18px" data-t="prob_title"></h2>
    <p class="lede" data-t="prob_lede"></p>
  </div>
  <div class="prob-grid">
    <div class="card hover" data-reveal data-reveal-delay="1">
      <div class="prob-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/><path d="M4 4l16 16"/></svg></div>
      <h3 class="h-md" data-t="prob1_t"></h3>
      <p class="muted mt-12" data-t="prob1_d"></p>
    </div>
    <div class="card hover" data-reveal data-reveal-delay="2">
      <div class="prob-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M3 9h18M9 21V9"/></svg></div>
      <h3 class="h-md" data-t="prob2_t"></h3>
      <p class="muted mt-12" data-t="prob2_d"></p>
    </div>
    <div class="card hover" data-reveal data-reveal-delay="3">
      <div class="prob-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg></div>
      <h3 class="h-md" data-t="prob3_t"></h3>
      <p class="muted mt-12" data-t="prob3_d"></p>
    </div>
  </div>
</section>

<!-- ============================ ANALYZER PREVIEW ============================ -->
<section class="section wrap" id="analyzer">
  <div class="sec-head" data-reveal>
    <div class="eyebrow"><span data-t="an_eyebrow"></span></div>
    <h2 class="display-md" style="margin-top:18px" data-t="an_title"></h2>
    <p class="lede" data-t="an_lede"></p>
  </div>
  <div class="an-card" data-reveal data-reveal-delay="1">
    <div class="an-left">
      <div class="an-handle">
        <div class="mock-pfp">M</div>
        <div>
          <div style="font-weight:700;font-size:17px;color:var(--cream)" data-t="mock_handle"></div>
          <div style="font-size:13px;color:var(--t-lo)" data-t="mock_meta"></div>
        </div>
      </div>
      <div class="an-metrics">
        <div class="kpi"><div class="kpi-label" data-t="an_m1"></div><div class="kpi-value tnum">6.2<span class="unit">%</span></div></div>
        <div class="kpi"><div class="kpi-label" data-t="an_m2"></div><div class="kpi-value tnum">8.8<span class="unit">K</span></div></div>
        <div class="kpi"><div class="kpi-label" data-t="an_m3"></div><div class="kpi-value tnum">412</div></div>
        <div class="kpi"><div class="kpi-label" data-t="an_m4"></div><div class="kpi-value">A<span class="unit">-grade</span></div></div>
      </div>
    </div>
    <div class="an-right">
      <div class="score-hero">
        <div class="ring">
          <svg width="92" height="92" viewBox="0 0 92 92">
            <circle cx="46" cy="46" r="40" fill="none" stroke="rgba(232,220,200,.1)" stroke-width="7"/>
            <circle cx="46" cy="46" r="40" fill="none" stroke="var(--lime)" stroke-width="7" stroke-linecap="round" stroke-dasharray="251" stroke-dashoffset="33" style="filter:drop-shadow(0 0 6px rgba(184,255,77,.6))"/>
          </svg>
          <div class="ring-num"><b style="font-size:26px;color:var(--cream)" class="tnum">87</b></div>
        </div>
        <div>
          <div class="eyebrow no-rule" style="margin-bottom:6px"><span data-t="mock_superfan"></span></div>
          <div style="font-size:13.5px;color:var(--t-mid);max-width:18em" data-t="mock_meta"></div>
        </div>
      </div>
      <div class="an-metrics">
        <div class="kpi"><div class="kpi-label" data-t="an_m5"></div><div class="kpi-value tnum hl">6.2<span class="unit">%</span></div></div>
        <div class="kpi"><div class="kpi-label" data-t="an_m6"></div><div class="kpi-value hl-gold">A+</div></div>
      </div>
      <div class="alert pos">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/></svg>
        <div><b style="display:block;margin-bottom:3px;color:var(--cream)" data-t="an_rec_t"></b><span data-t="an_rec_d"></span></div>
      </div>
      <a href="product/analyzer.html" class="btn btn-primary btn-block" data-t="an_run"></a>
    </div>
  </div>
</section>

<!-- ============================ JOURNEY ============================ -->
<section class="section wrap">
  <div class="sec-head center" data-reveal>
    <div class="eyebrow gold"><span data-t="tr_eyebrow"></span></div>
    <h2 class="display-md" style="margin-top:18px" data-t="tr_title"></h2>
    <p class="lede" data-t="tr_lede"></p>
  </div>
  <div class="journey">
    <div class="j-step" data-reveal data-reveal-delay="1"><div class="j-num">1</div><h4 data-t="tr_s1_t"></h4><p data-t="tr_s1_d"></p></div>
    <div class="j-step" data-reveal data-reveal-delay="2"><div class="j-num">2</div><h4 data-t="tr_s2_t"></h4><p data-t="tr_s2_d"></p></div>
    <div class="j-step" data-reveal data-reveal-delay="3"><div class="j-num">3</div><h4 data-t="tr_s3_t"></h4><p data-t="tr_s3_d"></p></div>
    <div class="j-step" data-reveal data-reveal-delay="4"><div class="j-num">4</div><h4 data-t="tr_s4_t"></h4><p data-t="tr_s4_d"></p></div>
    <div class="j-step" data-reveal data-reveal-delay="5"><div class="j-num">5</div><h4 data-t="tr_s5_t"></h4><p data-t="tr_s5_d"></p></div>
  </div>
</section>

<!-- ============================ TOKENIZATION ============================ -->
<section class="section wrap" id="loyalty">
  <div class="sec-head" data-reveal>
    <div class="eyebrow"><span data-t="tk_eyebrow"></span></div>
    <h2 class="display-md" style="margin-top:18px" data-t="tk_title"></h2>
    <p class="lede" data-t="tk_lede"></p>
  </div>
  <div class="tk-grid">
    <div class="card card-pad-lg" data-reveal data-reveal-delay="1">
      <div class="eyebrow no-rule" style="margin-bottom:20px"><span data-t="tk_fans"></span></div>
      <div class="tk-fans-grid">
        <div class="tk-chip"><span class="d"></span><span data-t="tk_f1"></span></div>
        <div class="tk-chip"><span class="d"></span><span data-t="tk_f2"></span></div>
        <div class="tk-chip"><span class="d"></span><span data-t="tk_f3"></span></div>
        <div class="tk-chip"><span class="d"></span><span data-t="tk_f4"></span></div>
        <div class="tk-chip"><span class="d"></span><span data-t="tk_f5"></span></div>
        <div class="tk-chip"><span class="d"></span><span data-t="tk_f6"></span></div>
        <div class="tk-chip"><span class="d"></span><span data-t="tk_f7"></span></div>
        <div class="tk-chip"><span class="d"></span><span data-t="tk_f8"></span></div>
      </div>
    </div>
    <div data-reveal data-reveal-delay="2">
      <div class="eyebrow gold no-rule" style="margin-bottom:20px"><span data-t="tk_you"></span></div>
      <div class="tk-power">
        <div class="tk-power-item"><b data-t="tk_p1"></b><span data-t="tk_disclaimer"></span></div>
        <div class="tk-power-item"><b data-t="tk_p2"></b></div>
        <div class="tk-power-item"><b data-t="tk_p3"></b></div>
        <div class="tk-power-item"><b data-t="tk_p4"></b></div>
      </div>
    </div>
  </div>
  <div class="alert sim mt-24" data-reveal>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
    <span data-t="tk_disclaimer"></span>
  </div>
</section>

<!-- ============================ DASHBOARD PREVIEW ============================ -->
<section class="section wrap">
  <div class="sec-head" data-reveal>
    <div class="eyebrow gold"><span data-t="db_eyebrow"></span></div>
    <h2 class="display-md" style="margin-top:18px" data-t="db_title"></h2>
    <p class="lede" data-t="db_lede"></p>
  </div>
  <div class="db-frame" data-reveal data-reveal-delay="1">
    <div class="db-bar">
      <span class="db-dot" style="background:#E07A4D"></span>
      <span class="db-dot" style="background:#E0B24D"></span>
      <span class="db-dot" style="background:#B8FF4D"></span>
      <span class="mono" style="font-size:12px;color:var(--t-lo);margin-left:12px">aura.app/dashboard</span>
    </div>
    <div class="db-body">
      <div class="db-kpis">
        <div class="kpi hover"><div class="kpi-label" data-t="db_k1"></div><div class="kpi-value tnum">87<span class="unit">/100</span></div><div class="kpi-foot"><span class="badge pos">+4</span><span data-t="db_k6"></span></div></div>
        <div class="kpi hover"><div class="kpi-label" data-t="db_k3"></div><div class="kpi-value tnum hl">$9.1K</div><div class="kpi-foot"><span class="badge pos">+18%</span></div></div>
        <div class="kpi hover"><div class="kpi-label" data-t="db_k4"></div><div class="kpi-value tnum">486</div><div class="kpi-foot"><span class="badge pos">+62</span></div></div>
      </div>
      <div class="db-lower">
        <div class="card card-pad-sm">
          <div class="row between" style="margin-bottom:6px"><span class="kpi-label" data-t="db_mod_rev"></span><span class="pill lime">$9.1K</span></div>
          <div class="bars">
            <div class="bar muted" style="height:38%"></div><div class="bar muted" style="height:46%"></div>
            <div class="bar muted" style="height:55%"></div><div class="bar" style="height:64%"></div>
            <div class="bar" style="height:78%"></div><div class="bar" style="height:92%"></div>
          </div>
        </div>
        <div class="card card-pad-sm">
          <div class="kpi-label" style="margin-bottom:14px" data-t="db_mod_funnel"></div>
          <div class="funnel-row"><div class="funnel-bar" style="width:100%"><span data-t="db_funnel_1"></span></div></div>
          <div class="funnel-row"><div class="funnel-bar" style="width:72%"><span data-t="db_funnel_2"></span></div></div>
          <div class="funnel-row"><div class="funnel-bar" style="width:38%"><span data-t="db_funnel_3"></span></div></div>
          <div class="funnel-row"><div class="funnel-bar" style="width:20%"><span data-t="db_funnel_4"></span></div></div>
        </div>
      </div>
      <div style="margin-top:18px"><a href="product/dashboard.html" class="btn btn-primary" data-t="db_open"></a></div>
    </div>
  </div>
</section>

