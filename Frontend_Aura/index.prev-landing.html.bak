<script>
/* ---- use case tiles ---- */
const ucIcons = ['star','users','box','key','play','calendar','gem','flag','gift','lock','coins','trophy'];
const ucSvg = {
  star:'<path d="M12 2l3 7 7 .5-5.5 4.5 2 7-6.5-4-6.5 4 2-7L2 9.5 9 9z"/>',
  users:'<circle cx="9" cy="8" r="3.5"/><path d="M2 21c0-4 3.5-6 7-6s7 2 7 6"/><path d="M17 11a3.5 3.5 0 100-7"/>',
  box:'<path d="M21 8l-9-5-9 5 9 5 9-5zM3 8v8l9 5 9-5V8"/>',
  key:'<circle cx="8" cy="15" r="4"/><path d="M11 12l9-9M18 5l2 2M15 8l2 2"/>',
  play:'<circle cx="12" cy="12" r="9"/><path d="M10 9l5 3-5 3z"/>',
  calendar:'<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/>',
  gem:'<path d="M6 3h12l4 6-10 12L2 9z"/><path d="M2 9h20M9 3L6 9l6 12 6-12-3-6"/>',
  flag:'<path d="M4 21V4M4 4h13l-2 4 2 4H4"/>',
  gift:'<rect x="3" y="8" width="18" height="13" rx="1"/><path d="M3 12h18M12 8v13M12 8S9 3 6.5 4.5 8 8 12 8zM12 8s3-5 5.5-3.5S16 8 12 8z"/>',
  lock:'<rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 018 0v3"/>',
  coins:'<ellipse cx="9" cy="7" rx="6" ry="3"/><path d="M3 7v5c0 1.7 2.7 3 6 3s6-1.3 6-3V7"/><path d="M15 11.5c2.5.4 6 1.6 6 3.5 0 1.7-2.7 3-6 3s-6-1.3-6-3"/>',
  trophy:'<path d="M7 4h10v5a5 5 0 01-10 0zM7 6H4v2a3 3 0 003 3M17 6h3v2a3 3 0 01-3 3M9 17h6M10 21h4M12 14v3"/>'
};
function renderUseCases() {
  const grid = document.getElementById('ucGrid');
  grid.innerHTML = '';
  for (let i = 1; i <= 12; i++) {
    const div = document.createElement('div');
    div.className = 'uc-tile';
    div.setAttribute('data-reveal','');
    div.innerHTML = `<div class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round">${ucSvg[ucIcons[i-1]]}</svg></div><h4 data-t="uc_${i}">${AuraI18n.get('uc_'+i)}</h4>`;
    grid.appendChild(div);
  }
}
/* ---- feature lists (pipe-split) ---- */
function renderFeats() {
  document.querySelectorAll('[data-feats]').forEach(ul => {
    const raw = AuraI18n.get(ul.getAttribute('data-feats'));
    ul.innerHTML = raw.split('|').map(f => `<li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6L9 17l-5-5"/></svg><span>${f}</span></li>`).join('');
  });
}

/* ---- hero figure (canvas) ---- */
function mountFigure(mode) {
  const canvas = document.getElementById('heroCanvas');
  if (!canvas || !window.AuraHero) return;
  const m = AuraHero.mount(canvas, mode);
  document.querySelectorAll('[data-fig]').forEach(b => b.classList.toggle('on', b.getAttribute('data-fig') === m.mode));
}

/* ---- mini sparklines on the stat band ---- */
function drawSparks() {
  const data = {
    a:[6,7,5,9,7,11,9,13,11,15,13,18,16,20],
    b:[10,9,12,10,14,11,15,13,17,14,18,16,19,21],
    c:[4,6,5,8,7,9,8,11,10,13,12,16,15,19],
    d:[9,7,10,8,12,9,13,11,14,12,15,13,17,19]
  };
  document.querySelectorAll('[data-spark]').forEach(svg => {
    const d = data[svg.getAttribute('data-spark')] || data.a;
    const w = 200, h = 30, max = Math.max(...d), min = Math.min(...d);
    const pts = d.map((v,i) => [i/(d.length-1)*w, h - 2 - (v-min)/(max-min||1)*(h-5)]);
    const line = pts.map((p,i)=>(i?'L':'M')+p[0].toFixed(1)+' '+p[1].toFixed(1)).join(' ');
    const area = line + ` L${w} ${h} L0 ${h} Z`;
    svg.innerHTML = `<path d="${area}" fill="rgba(184,255,77,.10)"/><path d="${line}" fill="none" stroke="var(--lime)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" vector-effect="non-scaling-stroke" style="filter:drop-shadow(0 0 3px rgba(184,255,77,.5))"/>`;
  });
}

renderUseCases();
renderFeats();
drawSparks();
AuraI18n.onChange(() => {
  renderUseCases(); renderFeats();
  AuraI18n.apply(document.getElementById('ucGrid'));
});

/* random figure on each visit; pager lets you preview the others */
mountFigure(AuraHero.randomMode());
document.querySelectorAll('[data-fig]').forEach(b =>
  b.addEventListener('click', () => mountFigure(b.getAttribute('data-fig'))));
</script>
</body>
</html>
