    <div class="eyebrow gold"><span data-t="pf_eyebrow"></span></div>
    <h2 class="display-md" style="margin-top:18px;max-width:16em" data-t="pf_title"></h2>
    <p class="lede" data-t="pf_lede"></p>
  </div>
  <div class="proof-grid">
    <div class="proof-card" data-reveal data-reveal-delay="1"><span class="pill gold" style="position:absolute;top:18px;right:18px" data-t="pf_sim_tag"></span><div class="v" data-t="pf_c1_v"></div><div class="l" data-t="pf_c1_l"></div><div class="d" data-t="pf_c1_d"></div></div>
    <div class="proof-card" data-reveal data-reveal-delay="2"><span class="pill gold" style="position:absolute;top:18px;right:18px" data-t="pf_sim_tag"></span><div class="v" data-t="pf_c2_v"></div><div class="l" data-t="pf_c2_l"></div><div class="d" data-t="pf_c2_d"></div></div>
    <div class="proof-card" data-reveal data-reveal-delay="3"><span class="pill gold" style="position:absolute;top:18px;right:18px" data-t="pf_sim_tag"></span><div class="v" data-t="pf_c3_v"></div><div class="l" data-t="pf_c3_l"></div><div class="d" data-t="pf_c3_d"></div></div>
  </div>
  <div class="quote" data-reveal>
