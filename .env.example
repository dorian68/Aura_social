# Official Instagram Graph API for public Business Discovery and owned-account audits.
# Use a token generated through Meta Login/OAuth with approved Instagram permissions.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_GRAPH_VERSION=v23.0
INSTAGRAM_AUDIT_OUTPUT_DIR=data/instagram
INSTAGRAM_AUDIT_POST_LIMIT=100
INSTAGRAM_AUDIT_DAYS=30

# Meta OAuth / private insights in the Next.js app.
# In local development these can also be saved from the dashboard UI.
APP_ID=
APP_SECRET=
GRAPH_API_VERSION=v23.0
META_AUTH_MODE=instagram
FACEBOOK_LOGIN_CONFIG_ID=
FRONTEND_URL=http://localhost:3170
MOCK_META=false
ALLOW_RUNTIME_SETUP=false
META_LOG_DIR=data/meta/logs
META_RUNTIME_CONFIG_FILE=data/meta/runtime-config.local.json
META_DEBUG_PROVIDER=instagram
META_DEBUG_ACCESS_TOKEN=
META_DEBUG_IG_USER_ID=me

# Local MVP persistence.
# Use AURA_PERSISTENCE=memory to disable local JSON state files during tests.
AURA_PERSISTENCE=local
AURA_STATE_DIR=data/aura-state
SMOKE_BASE_URL=http://localhost:3170

# Aura B2B Expansion Agent.
# MVP uses mock discovery/payment/outreach. Leave these empty until real integrations are added.
B2B_AGENT_MODE=mock
GOOGLE_PLACES_API_KEY=
STRIPE_SECRET_KEY=
CRM_API_KEY=
EMAIL_PROVIDER_API_KEY=
OUTREACH_SENDING_ENABLED=false

# Aura Operator — Natural Language Control Agent
# OPERATOR_MODE=rules uses deterministic routing (no LLM required).
# Set to llm and configure an LLM provider when ready.
OPERATOR_MODE=rules
OPERATOR_ENABLE_LLM=false
