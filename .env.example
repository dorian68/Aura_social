# ════════════════════════════════════════════════════════════════════════
#  Aura — environment template.  Copy to .env:   cp .env.example .env
#  Defaults below are MOCK-SAFE: the app boots and the smoke tests pass with
#  NO real credentials and NO external services. Fill real values only when
#  you intentionally go live.  Never commit a filled .env.
# ════════════════════════════════════════════════════════════════════════

# ── Runtime / network ───────────────────────────────────────────────────
NODE_ENV=development
# Port the Next.js app (API + pages) listens on. Server binds 0.0.0.0 in Docker.
PORT=3000
# Port the static Frontend_Aura product UI is served on (docker "web" service).
WEB_PORT=8080
# Public URL of the app (used to build OAuth redirect URIs). Set to your VPS
# domain in production, e.g. https://aura.example.com
FRONTEND_URL=http://localhost:3000
# Production API identities. Prefer AURA_API_KEYS_JSON for roles/workspaces.
# Example:
# AURA_API_KEYS_JSON=[{"token":"replace-with-32-plus-random-chars","subject":"operator@example.com","role":"operator","workspaceIds":["workspace_aura_demo"]}]
AURA_API_KEYS_JSON=
# Legacy single admin token, supported for backwards compatibility.
AURA_API_TOKEN=
DEMO_MODE=false

# ── Mock mode (keep these for dependency-free dev) ──────────────────────
# MOCK_META=true → no real Meta/Instagram calls; OAuth & insights are simulated.
MOCK_META=true
# AGENT_MODE=rules → deterministic agent (no LLM). B2B/outreach are simulated.
AGENT_MODE=rules
OPERATOR_MODE=rules
OPERATOR_ENABLE_LLM=false

# ── AG-UI assistant (chatbot streaming layer) ───────────────────────────
# Default LLM is OpenAI gpt-4o-mini to keep inference costs low. With NO key,
# the assistant streams Aura's deterministic operator answers (safe, grounded).
# The model only rephrases prose; facts/tools always come from the real engine.
AG_UI_PROVIDER=openai
AG_UI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# Sensitive tools always require human confirmation unless set to "false".
AG_UI_REQUIRE_APPROVAL=true
AG_UI_ENABLE_DEBUG=false
# Optional, off by default — never escalate to a costlier model unless enabled.
AG_UI_ESCALATION_MODEL=
AG_UI_ENABLE_MODEL_ESCALATION=false

# ── Meta / Instagram Graph API (only needed when MOCK_META=false) ────────
APP_ID=
APP_SECRET=
GRAPH_API_VERSION=v23.0
# instagram = Instagram Login direct (own-account insights).
# facebook  = Facebook Login for Business (enables Business Discovery / search).
META_AUTH_MODE=instagram
FACEBOOK_LOGIN_CONFIG_ID=
ALLOW_RUNTIME_SETUP=true
# Connected-account session lifetime (hours). In-memory; also bounded by uptime.
META_CONNECTION_TTL_HOURS=720
META_LOG_DIR=data/meta/logs
META_LOG_FILE=data/meta/logs/aura-meta.ndjson
META_RUNTIME_CONFIG_FILE=data/meta/runtime-config.local.json

# ── Business Discovery source (operator-level, optional) ─────────────────
# One business-account token that powers "search any creator" for all users.
# Generate once via Graph API Explorer (instagram_basic + pages_show_list +
# pages_read_engagement). Leave empty to disable creator search.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_GRAPH_VERSION=v23.0
# Owned-account audit script tuning (scripts/instagram-creator-audit.mjs):
INSTAGRAM_AUDIT_OUTPUT_DIR=data/instagram
INSTAGRAM_AUDIT_POST_LIMIT=100
INSTAGRAM_AUDIT_DAYS=30

# ── Debug helpers (scripts/debug-meta-flow.mjs) ─────────────────────────
META_DEBUG_PROVIDER=instagram
META_DEBUG_ACCESS_TOKEN=
META_DEBUG_IG_USER_ID=me

# ── Durable persistence ──────────────────────────────────────────────────
# sqlite is the default. memory is ephemeral; local_json is legacy only.
AURA_PERSISTENCE=sqlite
AURA_DATABASE_PATH=data/aura-state/aura.sqlite
# DATABASE_URL may also use file: or sqlite: for a SQLite path.
DATABASE_URL=
AURA_STATE_DIR=data/aura-state
SMOKE_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:8080
# Enables the protected /api/test/reset fixture endpoint outside production.
AURA_TEST_MODE=false

# ── Blockchain (optional; falls back to mock when no node) ──────────────
# A reachable Hardhat/EVM node is NOT required — contract calls are simulated.
HARDHAT_RPC_URL=http://127.0.0.1:8545
AURA_POINTS_CONTRACT_ADDRESS=
AURA_FAN_PASS_CONTRACT_ADDRESS=
AURA_REWARD_REGISTRY_CONTRACT_ADDRESS=

# ── Real-world side-effect gates (DANGEROUS — default OFF) ───────────────
# Each must be "true" to allow a real side effect; otherwise it is simulated.
AURA_ALLOW_ONCHAIN_WRITES=false
OUTREACH_SENDING_ENABLED=false
AURA_ALLOW_REAL_PAYMENTS=false
AURA_ALLOW_REAL_DISCOVERY=false
STRIPE_ALLOW_LIVE_MODE=false

# ── External providers (only when going live; unused in mock mode) ──────
GOOGLE_PLACES_API_KEY=
B2B_DISCOVERY_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
OUTREACH_PROVIDER=resend
EMAIL_PROVIDER_API_KEY=
EMAIL_PROVIDER_FROM=
